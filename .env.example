# =============================================================================
# ZK privacy pool (ZKPrivacyPool + PrivPayGroth16Verifier + linked PoseidonT3 library)
# Deploy: npm run deploy:pool  → prints pool, verifier, and Poseidon library addresses
# =============================================================================

# On-chain pools (browser + server recurring): one pool per token.
# Backward compatibility: VITE_PRIVACY_POOL_ADDRESS is treated as USDC pool if *_USDC is unset.
VITE_PRIVACY_POOL_ADDRESS_USDC=
VITE_PRIVACY_POOL_ADDRESS_EURC=
VITE_PRIVACY_POOL_ADDRESS_SWPRC=
# Legacy single-pool fallback (USDC)
# VITE_PRIVACY_POOL_ADDRESS=

# First block where this pool contract exists (printed by npm run deploy:pool). Required for fast log scans on Arc (10k getLogs range cap).
VITE_PRIVACY_POOL_FROM_BLOCK=

# Groth16 verifier contract (same network as pool; informational / tooling — verifier is immutable on the pool)
PRIVACY_POOL_VERIFIER_ADDRESS=

# Set automatically by deploy script (informational; pool bytecode links to this library on-chain)
# POSEIDON_T3_LIBRARY_ADDRESS=

# --- RPC ---
# Node (relay, API routes, scripts). Browser read RPC defaults to https://rpc.testnet.arc.network if unset.
ARC_RPC_URL=https://rpc.testnet.arc.network
VITE_ARC_RPC_URL=
ARC_CHAIN_ID=5042002

# --- Relayer — POST /api/privpay/privacy-pool-relay (action: deposit | withdraw; EIP-712 required) ---
VITE_PRIVACY_POOL_USE_RELAY=false
PRIVACY_POOL_RELAYER_PRIVATE_KEY=
PRIVPAY_RELAY_SERVER_SECRET=
# Optional: comma-separated pools; include all token pools for relay/cron.
# PRIVPAY_ALLOWED_POOL_ADDRESSES=
# Server-side per-token pool mapping (used by recurring Bills + Payroll)
# PRIVACY_POOL_ADDRESS_USDC=
# PRIVACY_POOL_ADDRESS_EURC=
# PRIVACY_POOL_ADDRESS_SWPRC=
PRIVPAY_RELAY_RPM=30
PRIVPAY_RELAY_MAX_DEADLINE_SEC=600
PRIVPAY_RELAY_RL_PEPPER=
# Set to 1 on Vercel if you rely on KV for relay rate limits (no in-memory fallback when KV errors).
# PRIVPAY_RELAY_REQUIRE_KV=1
# PRIVPAY_RELAY_DEBUG=1

# --- Deploy script (scripts/deployPrivacyPool.mjs) ---
PRIVACY_POOL_TOKEN=0x3600000000000000000000000000000000000000
PRIVACY_POOL_MERKLE_HEIGHT=16
PRIVPAY_VERIFICATION_KEY_JSON=build/privpay/verification_key.json
ARC_DEPLOYER_PRIVATE_KEY=
# Treasury deployer for swap pool V2 — MUST be 0xD4d3… private key (deployer + owner on Arcscan)
# MY_PK=
# SWAP_POOL_OWNER_ADDRESS=0xD4d3E342902766344075D06c94391e61A9bB7e60

# --- Swap pool V2 (UUPS proxy) — after migration cutover ---
# VITE_SWAP_POOL_ADDRESS=
# SWAP_POOL_ADDRESS=
# SWAP_POOL_IMPLEMENTATION=
# SWAP_POOL_A=200
# SWAP_POOL_FEE_BPS=4

# --- Browser Groth16 proving (claim flow) — serve wasm + zkey under public/ or CDN ---
# VITE_PRIVPAY_WASM_URL=/circuits/privpay/privpay_claim.wasm
# VITE_PRIVPAY_ZKEY_URL=/circuits/privpay/privpay_claim_final.zkey

# --- Recurring autopay: Bills + Payroll (same server job; relayer signs deposits) ---
# While the app is open, the client also POSTs /api/payments/recurring/run and /api/payments/payroll/run
# so due payments run without Cron. For "offline" runs, add Vercel Cron hitting those routes.
# Vercel Cron invokes with Authorization: Bearer CRON_SECRET when CRON_SECRET is set.
# CRON_SECRET=
# Required for any automatic run (Bills or Payroll). Set true when PRIVACY_POOL_RELAYER_PRIVATE_KEY
# and pool addresses are configured (see PRIVACY_POOL_ADDRESS_* above).
# RECURRING_SERVER_EXECUTION_ENABLED=false
# Optional on-chain recurring guard (recommended): deploy via `npm run deploy:recurring-automation`.
# Users authorize this contract once per schedule; server relayer executes within on-chain caps.
# RECURRING_AUTOMATION_CONTRACT_ADDRESS=
# VITE_RECURRING_AUTOMATION_CONTRACT_ADDRESS=
# Public executor address (derived from PRIVACY_POOL_RELAYER_PRIVATE_KEY) used for on-chain schedule authorization.
# VITE_RECURRING_AUTOMATION_EXECUTOR_ADDRESS=
# Set true to enforce authorization strictly (runs fail if auth missing); default false keeps legacy fallback.
# RECURRING_AUTOMATION_STRICT=false
# Recurring relayer gas: when balance < TARGET_MIN, sponsor sends TOPUP (or shortfall+MARGIN if larger).
# RECURRING_RELAYER_TARGET_MIN_ARC=0.2
# RECURRING_RELAYER_TOPUP_ARC=0.12
# RECURRING_RELAYER_TOPUP_MARGIN_ARC=0.02
# RECURRING_RELAYER_GAS_SPONSOR_PRIVATE_KEY=
# Server-side usage fee for automated runs (USDC transferFrom via relay); set treasury to match browser.
# ARCPAY_TREASURY_ADDRESS=
# ARCPAY_USDC_ADDRESS=0x3600000000000000000000000000000000000000
# ARCPAY_USAGE_FEE_USDC=0.02

# --- KV / Redis (profiles, leaderboard, payroll, privpay relay limits, replay protection) ---
# Preferred: TCP Redis (Railway Redis, Redis Cloud, etc.). Same REDIS_URL on Vercel + Railway indexer.
# REDIS_URL=redis://default:PASSWORD@HOST:6379
# TLS: rediss://...
# Legacy Upstash REST (per-request billing) — only if REDIS_URL is unset:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Landing network stats (weekly cron → Vercel Blob; see docs/swaparc/operate/jobs-and-healthchecks.md) ---
# BLOB_READ_WRITE_TOKEN=
# VITE_LANDING_STATS_URL=https://xxxx.public.blob.vercel-storage.com/landing-network.json
# npm run stats:publish-landing

# Other SwapARC features (Circle auth, stealth, payroll KV encryption, cron, …) read additional
# variables — grep the repo for process.env and import.meta.env if you need the full set.
